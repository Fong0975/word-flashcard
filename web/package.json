{
  "name": "word-flashcard",
  "version": "1.0.41",
  "private": true,
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --coverage",
    "test:ctrf": "react-scripts test --watchAll=false --coverage --reporters=default --reporters=jest-ctrf-json-reporter",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint src --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json,css}",
    "format:check": "prettier --check src/**/*.{ts,tsx,js,jsx,json,css}",
    "format:diff": "prettier --list-different src/**/*.{ts,tsx,js,jsx,json,css}"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "@tootallnate/once": "^2.0.1",
    "nth-check": "^2.1.1",
    "serialize-javascript": "^7.0.5",
    "underscore": "^1.13.8",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.24",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "jest-ctrf-json-reporter": "0.0.9",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.15"
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^unist-util-visit-parents/do-not-use-color$": "<rootDir>/node_modules/unist-util-visit-parents/lib/color.js",
      "^#minpath$": "<rootDir>/node_modules/vfile/lib/minpath.browser.js",
      "^#minproc$": "<rootDir>/node_modules/vfile/lib/minproc.browser.js",
      "^#minurl$": "<rootDir>/node_modules/vfile/lib/minurl.browser.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\](?!(react-markdown|remark-.*|rehype-.*|mdast-util-.*|hast-util-.*|micromark.*|unist-util-.*|unified|vfile.*|hastscript|bail|trough|zwitch|devlop|ccount|longest-streak|markdown-table|stringify-entities|trim-lines|property-information|space-separated-tokens|comma-separated-tokens|web-namespaces|html-void-elements|html-url-attributes|html-entities|decode-named-character-reference|character-entities.*|character-reference-invalid|parse-entities|is-alphabetical|is-alphanumerical|is-decimal|is-hexadecimal|estree-util-is-identifier-name|entities|parse5|escape-string-regexp|is-plain-obj)[/\\\\]).+\\.(js|jsx|mjs|cjs|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ]
  }
}
